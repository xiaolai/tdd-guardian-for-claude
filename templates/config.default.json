{
  "enabled": true,
  "enforceOnCodeChange": true,
  "blockCommitWithoutFreshGate": true,
  "gateFreshnessMinutes": 120,
  "bypassEnv": "TDD_GUARD_BYPASS",
  "preflightCommand": "",
  "testCommand": "pnpm test",
  "coverageCommand": "pnpm test -- --coverage",
  "coverageSummaryPath": "coverage/coverage-summary.json",
  "coverageThresholds": {
    "lines": 100,
    "functions": 100,
    "branches": 100,
    "statements": 100
  },
  "coverageMode": "absolute",
  "smartStaleness": true,
  "installCustomAgents": false,
  "requireMutation": false,
  "mutationCommand": "",
  "sourceExtensions": [
    ".js",
    ".jsx",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx",
    ".py",
    ".rb",
    ".go",
    ".rs",
    ".java",
    ".kt",
    ".swift",
    ".c",
    ".cc",
    ".cpp",
    ".h",
    ".hpp",
    ".cs",
    ".php",
    ".sh",
    ".bash",
    ".zsh",
    ".fish",
    ".sql",
    ".html",
    ".css",
    ".scss",
    ".vue",
    ".svelte"
  ],
  "ignorePaths": [
    ".git",
    ".codex/tdd-guardian/logs",
    "node_modules",
    "coverage",
    "dist",
    "build",
    ".next",
    ".nuxt",
    "target",
    ".venv",
    "venv"
  ]
}
